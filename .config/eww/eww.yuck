(defpoll time :interval "1s"
  `date +'{"hour":"%H","min":"%M", "sec":"%S"}'`)

(defwindow powermenu
  :monitor 0
  :stacking "fg"
  :windowtype "dock"
  :exclusive true
  :wm-ignore false
  :geometry (geometry
              :width "100%"
              :height "2%"
              :anchor "top center")
  (label 
    :text "${time.hour}:${time.min}"
    :halign "end"
    ))

